---
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Layout from '../layouts/Layout.astro';
import { kingdoms } from '../data/site';
---

<Layout title="王国与势力 | 枭暖史书" description="幻想世界的国家、教团、商盟与组织架构。" path="/kingdoms">
  <SiteHeader />

  <main class="page-main">
    <div class="container">
      <section class="paper-panel page-hero">
        <div class="eyebrow">王国与势力</div>
        <h1 class="page-title">帝国与联盟并峙，学院与组织交错。</h1>
        <p class="lead">
          这里先放“制度级势力”的条目：北方统一帝国、南方万国联盟、学院体系与校联合部门。后续你可以继续补各国、宗派、军团与地下组织。
        </p>
      </section>

      <section class="grid cards-3">
        {kingdoms.map((kingdom) => (
          <article class="card">
            <h3>{kingdom.name}</h3>
            <p><strong>{kingdom.seat}</strong> · {kingdom.alignment}</p>
            <p>{kingdom.summary}</p>
          </article>
        ))}
      </section>
    </div>
  </main>
  <SiteFooter />
</Layout>
