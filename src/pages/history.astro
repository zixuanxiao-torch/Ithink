---
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Layout from '../layouts/Layout.astro';
import { timeline } from '../data/site';
---

<Layout title="编年史 | 枭暖史书" description="幻想世界的纪元、战争与王朝更替。" path="/history">
  <SiteHeader />

  <main class="page-main">
    <div class="container">
      <section class="paper-panel page-hero">
        <div class="eyebrow">编年史</div>
        <h1 class="page-title">把南北对峙与学院崛起，写成可追溯的年代线。</h1>
        <p class="lead">
          这里记录制度如何成形：沙漠带如何分割南北，帝国如何统一，学院如何从实力立足变成资格中枢，四年四会如何成为公开筛选。
        </p>
      </section>

      <section class="timeline">
        {timeline.map((item) => (
          <article class="timeline-item">
            <time>{item.year}</time>
            <h3>{item.title}</h3>
            <p class="timeline-era">{item.era}</p>
            <p>{item.description}</p>
          </article>
        ))}
      </section>
    </div>
  </main>
  <SiteFooter />
</Layout>
