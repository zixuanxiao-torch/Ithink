---
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Layout from '../layouts/Layout.astro';
import { personae } from '../data/site';
---

<Layout title="人物列传 | 枭暖史书" description="幻想世界的重要人物、血脉、立场与事迹。" path="/personae">
  <SiteHeader />

  <main class="page-main">
    <div class="container">
      <section class="paper-panel page-hero">
        <div class="eyebrow">人物列传</div>
        <h1 class="page-title">把常量与变量，都写进同一部史书。</h1>
        <p class="lead">
          这里先收录明暗榜的核心人物与学院关键创始者。后续可以逐步补全门派领袖、帝国机构、地方诸王与地下世界的名字。
        </p>
      </section>

      <section class="grid cards-3">
        {personae.map((person) => (
          <article class="card">
            <h3>{person.name}</h3>
            <p><strong>{person.role}</strong></p>
            <p>{person.allegiance}</p>
            <p>{person.note}</p>
          </article>
        ))}
      </section>
    </div>
  </main>
  <SiteFooter />
</Layout>
